{
  "name": "simstock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "cf:typegen": "wrangler types src/cloudflare-env.d.ts",
    "cf:build": "opennextjs-cloudflare build --skipWranglerConfigCheck",
    "cf:preview": "opennextjs-cloudflare build --skipWranglerConfigCheck && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build --skipWranglerConfigCheck && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.74.0"
  }
}
