generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum VerticalStatus {
  ACTIVE
  INACTIVE
}

enum VerticalDefinitionStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum VerticalDropletStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum DropletType {
  READONLY_TABLE
  ANALYSIS_CARD
  EDITABLE_TABLE
  FORM
  MIXED_OUTPUT
}

enum TenantShellStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INVITED
  INACTIVE
  SUSPENDED
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum MembershipStatus {
  ACTIVE
  INVITED
  INACTIVE
}

enum CustomerStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum OrderStatus {
  DRAFT
  BOOKED
  INVOICED
  CANCELLED
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum AccountType {
  CUSTOMER
  SUPPLIER
  PARTNER
  OTHER
}

enum AddressType {
  BILLING
  SHIPPING
  WAREHOUSE
  OFFICE
  OTHER
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum EcommerceChannelType {
  SHOPIFY
  AMAZON
  WEBSITE
  MARKETPLACE
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
}

enum LedgerType {
  GENERAL
  SALES
  PURCHASES
  INVENTORY
  OTHER
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COGS
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum PeriodGranularity {
  DAY
  WEEK
  MONTH
  QUARTER
  YEAR
}

enum MetricScope {
  GLOBAL
  VERTICAL
  TENANT
}

enum MetricUnit {
  CURRENCY
  NUMBER
  PERCENTAGE
  DAYS
}

enum MetricAggregationMethod {
  SUM
  AVG
  LAST
  COUNT
  RATIO
}

enum MetricScenario {
  ACTUAL
  FORECAST
  TARGET
  BUDGET
  PLAN
}

enum PlanType {
  TARGET
  BUDGET
  FORECAST
  PLAN
}

enum PlanStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
}

enum MarketingAssetType {
  ARTICLE
  POST
  VIDEO
  AD
  EMAIL
  LANDING_PAGE_COPY
  OTHER
}

enum CommandScope {
  GLOBAL
  VERTICAL
  TENANT
  DROPLET
}

model Tenant {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  status                   TenantStatus              @default(ACTIVE)
  defaultCurrency          String
  defaultTimezone          String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  settings                 TenantSettings?
  company                  Company?
  tenantShells             TenantShell[]
  people                   Person[]
  revenueSnapshots         RevenueSnapshot[]
  headcountRecords         HeadcountSnapshot[]
  customers                Customer[]
  orders                   Order[]
  salesStages              SalesStage[]
  opportunities            Opportunity[]
  stageEvents              OpportunityStageEvent[]
  tenantDropletAssignments TenantDropletAssignment[]
  importJobs               DataImportJob[]
  auditLogs                AuditLog[]
}

model TenantSettings {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  configJson Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Vertical {
  id                 String                   @id @default(cuid())
  key                String                   @unique
  name               String
  description        String?
  category           String?
  icon               String?
  color              String?
  status             VerticalStatus           @default(ACTIVE)
  version            Int                      @default(1)
  metadataJson       Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  createdByUserId    String?
  updatedByUserId    String?
  createdByUser      User?                    @relation("VerticalCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser      User?                    @relation("VerticalUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  definitions        VerticalDefinition[]
  droplets           VerticalDroplet[]
  promptTemplates    PromptTemplate[]
  dummyDataScenarios DummyDataScenario[]
  tenantShells       TenantShell[]
  companies          Company[]
  verticalSkills     VerticalSkill[]
  userMemberships    UserVerticalMembership[]
  verticalLlmConfigs VerticalLLMConfig[]

  @@index([status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model VerticalDefinition {
  id                      String                   @id @default(cuid())
  verticalId              String
  version                 Int
  commonModelConfigJson   Json
  verticalModelConfigJson Json
  llmConfigJson           Json
  commandPackJson         Json
  skillPackJson           Json
  orgChartTemplateJson    Json
  status                  VerticalDefinitionStatus @default(DRAFT)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  vertical                Vertical                 @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  tenantShells            TenantShell[]

  @@unique([verticalId, version])
  @@index([verticalId])
  @@index([verticalId, status])
}

model VerticalDroplet {
  id                         String                    @id @default(cuid())
  verticalId                 String
  name                       String
  slug                       String
  description                String?
  dropletType                DropletType
  command                    String
  commandAliasesJson         Json?
  commandHelpText            String?
  authorHintText             String?
  shadowSkillDefinitionJson  Json?
  generationPromptVersion    String?
  generationStatus           String                    @default("draft")
  generationWarningsJson     Json?
  previewDummyDataConfigJson Json?
  dropletDefinitionJson      Json
  supportedEntitiesJson      Json?
  status                     VerticalDropletStatus     @default(DRAFT)
  version                    Int                       @default(1)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  vertical                   Vertical                  @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  assignments                TenantDropletAssignment[]
  versions                   VerticalDropletVersion[]

  @@unique([verticalId, slug])
  @@unique([verticalId, command])
  @@index([verticalId])
  @@index([verticalId, status])
  @@index([verticalId, generationStatus])
}

model VerticalDropletVersion {
  id                        String          @id @default(cuid())
  verticalDropletId         String
  version                   Int
  shadowSkillDefinitionJson Json
  authorHintText            String?
  generationPromptVersion   String?
  generationWarningsJson    Json?
  statusSnapshot            String
  createdAt                 DateTime        @default(now())
  createdByUserId           String?
  verticalDroplet           VerticalDroplet @relation(fields: [verticalDropletId], references: [id], onDelete: Cascade)
  createdByUser             User?           @relation("VerticalDropletVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([verticalDropletId, version])
  @@index([verticalDropletId])
  @@index([createdByUserId])
}

model PromptTemplate {
  id           String       @id @default(cuid())
  verticalId   String?
  key          String
  name         String
  purpose      String
  templateText String
  version      Int          @default(1)
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  vertical     Vertical?    @relation(fields: [verticalId], references: [id], onDelete: SetNull)

  @@unique([key, version])
  @@index([verticalId])
  @@index([status])
}

model DummyDataScenario {
  id           String       @id @default(cuid())
  verticalId   String?
  key          String       @unique
  name         String
  description  String?
  entity       String
  scenarioJson Json
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  vertical     Vertical?    @relation(fields: [verticalId], references: [id], onDelete: SetNull)

  @@index([verticalId])
  @@index([status])
  @@index([entity])
}

model TenantShell {
  id                   String             @id @default(cuid())
  tenantId             String
  verticalId           String
  verticalDefinitionId String
  name                 String
  slug                 String
  configJson           Json
  status               TenantShellStatus  @default(ACTIVE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vertical             Vertical           @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  verticalDefinition   VerticalDefinition @relation(fields: [verticalDefinitionId], references: [id], onDelete: Restrict)

  @@unique([tenantId, verticalId])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([verticalId])
  @@index([verticalDefinitionId])
}

model TenantDropletAssignment {
  id                 String          @id @default(cuid())
  tenantId           String
  companyId          String?
  verticalDropletId  String
  nameOverride       String?
  placement          String?
  configOverrideJson Json
  active             Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  verticalDroplet    VerticalDroplet @relation(fields: [verticalDropletId], references: [id], onDelete: Restrict)

  @@unique([tenantId, verticalDropletId])
  @@index([tenantId])
  @@index([companyId])
  @@index([tenantId, active])
  @@index([verticalDropletId])
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  firstName              String
  lastName               String
  displayName            String
  passwordHash           String?
  authProvider           String?
  authProviderUserId     String?
  emailVerifiedAt        DateTime?
  lastLoginAt            DateTime?
  status                 UserStatus               @default(ACTIVE)
  globalRole             String?
  metadataJson           Json?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  verticalMemberships    UserVerticalMembership[]
  companyMemberships     UserCompanyMembership[]
  createdVerticals       Vertical[]               @relation("VerticalCreatedBy")
  updatedVerticals       Vertical[]               @relation("VerticalUpdatedBy")
  createdSkills          Skill[]                  @relation("SkillCreatedBy")
  updatedSkills          Skill[]                  @relation("SkillUpdatedBy")
  createdCompanies       Company[]                @relation("CompanyCreatedBy")
  updatedCompanies       Company[]                @relation("CompanyUpdatedBy")
  createdDropletVersions VerticalDropletVersion[] @relation("VerticalDropletVersionCreatedBy")
  auditLogs              AuditLog[]               @relation("AuditActor")
  queryContexts          QueryContext[]

  @@unique([authProvider, authProviderUserId])
  @@index([status])
  @@index([globalRole])
}

model Skill {
  id               String          @id @default(cuid())
  key              String          @unique
  name             String
  description      String
  instructions     String
  triggerHintsJson Json?
  inputSchemaJson  Json?
  outputSchemaJson Json?
  toolsConfigJson  Json?
  examplesJson     Json?
  tagsJson         Json?
  version          Int             @default(1)
  status           RecordStatus    @default(ACTIVE)
  metadataJson     Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdByUserId  String?
  updatedByUserId  String?
  createdByUser    User?           @relation("SkillCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser    User?           @relation("SkillUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  verticals        VerticalSkill[]

  @@index([status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model VerticalSkill {
  id         String   @id @default(cuid())
  verticalId String
  skillId    String
  priority   Int?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  vertical   Vertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([verticalId, skillId])
  @@index([verticalId])
  @@index([skillId])
  @@index([active])
}

model Company {
  id                       String                    @id @default(cuid())
  tenantId                 String?                   @unique
  key                      String                    @unique
  name                     String
  legalName                String?
  slug                     String                    @unique
  taxId                    String?
  country                  String?
  timezone                 String?
  currency                 String?
  status                   RecordStatus              @default(ACTIVE)
  verticalId               String
  metadataJson             Json?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  createdByUserId          String?
  updatedByUserId          String?
  tenant                   Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  vertical                 Vertical                  @relation(fields: [verticalId], references: [id], onDelete: Restrict)
  createdByUser            User?                     @relation("CompanyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser            User?                     @relation("CompanyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  userMemberships          UserCompanyMembership[]
  tenantDropletAssignments TenantDropletAssignment[]
  people                   Person[]
  orgUnits                 OrgUnit[]
  teams                    Team[]
  accounts                 Account[]
  contacts                 Contact[]
  addresses                Address[]
  leads                    Lead[]
  opportunityStages        OpportunityStage[]
  quotes                   Quote[]
  quoteLines               QuoteLine[]
  ecommerceChannels        EcommerceChannel[]
  carts                    Cart[]
  cartLines                CartLine[]
  salesOrders              SalesOrder[]
  salesOrderLines          SalesOrderLine[]
  fulfillments             Fulfillment[]
  salesReturns             SalesReturn[]
  productCategories        ProductCategory[]
  products                 Product[]
  priceLists               PriceList[]
  priceListItems           PriceListItem[]
  warehouses               Warehouse[]
  inventoryItems           InventoryItem[]
  inventoryTransactions    InventoryTransaction[]
  stockAdjustments         StockAdjustment[]
  stockAdjustmentLines     StockAdjustmentLine[]
  inventoryTransfers       InventoryTransfer[]
  inventoryTransferLines   InventoryTransferLine[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderLines       PurchaseOrderLine[]
  goodsReceipts            GoodsReceipt[]
  goodsReceiptLines        GoodsReceiptLine[]
  fiscalPeriods            FiscalPeriod[]
  ledgers                  Ledger[]
  ledgerAccounts           LedgerAccount[]
  journalEntries           JournalEntry[]
  journalEntryLines        JournalEntryLine[]
  invoices                 Invoice[]
  invoiceLines             InvoiceLine[]
  payments                 Payment[]
  expenses                 Expense[]
  timePeriods              TimePeriod[]
  metricDefinitions        MetricDefinition[]
  metricSeries             MetricSeries[]
  metricPoints             MetricPoint[]
  forecastModels           ForecastModel[]
  planVersions             PlanVersion[]
  revenueSnapshots         RevenueSnapshot[]
  headcountSnapshots       HeadcountSnapshot[]
  marketingWorkspaces      MarketingWorkspace[]
  marketingCampaigns       MarketingCampaign[]
  contentAssets            ContentAsset[]
  socialPosts              SocialPost[]
  landingPages             LandingPage[]
  marketingContacts        MarketingContact[]
  marketingLeads           MarketingLead[]
  funnelStages             FunnelStageDefinition[]
  funnelEvents             FunnelEvent[]
  documents                Document[]
  meetings                 Meeting[]
  transcripts              Transcript[]
  notes                    Note[]
  tasks                    Task[]
  decisions                Decision[]
  risks                    Risk[]
  entityLinks              EntityLink[]
  observations             Observation[]
  queryContexts            QueryContext[]
  commandDefinitions       CommandDefinition[]
  skillDefinitions         SkillDefinition[]
  opportunities            Opportunity[]
  opportunityStageEvents   OpportunityStageEvent[]
  auditLogs                AuditLog[]

  @@index([verticalId])
  @@index([status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model UserCompanyMembership {
  id        String           @id @default(cuid())
  userId    String
  companyId String
  role      String
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model UserVerticalMembership {
  id         String           @id @default(cuid())
  userId     String
  verticalId String
  role       String
  status     MembershipStatus @default(ACTIVE)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vertical   Vertical         @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([userId, verticalId])
  @@index([userId])
  @@index([verticalId])
  @@index([status])
}

model LLMProviderConfig {
  id                  String              @id @default(cuid())
  providerKey         String              @unique
  name                String
  status              RecordStatus        @default(ACTIVE)
  baseUrl             String?
  apiKeyRef           String?
  configJson          Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  modelConfigs        LLMModelConfig[]
  verticalAssignments VerticalLLMConfig[]

  @@index([status])
}

model LLMModelConfig {
  id                       String              @id @default(cuid())
  providerConfigId         String
  modelKey                 String
  displayName              String
  status                   RecordStatus        @default(ACTIVE)
  isDefault                Boolean             @default(false)
  temperature              Decimal?            @db.Decimal(3, 2)
  maxTokens                Int?
  supportsTools            Boolean?
  supportsStructuredOutput Boolean?
  configJson               Json?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  providerConfig           LLMProviderConfig   @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)
  verticalAssignments      VerticalLLMConfig[]

  @@unique([providerConfigId, modelKey])
  @@index([providerConfigId])
  @@index([status])
  @@index([providerConfigId, isDefault])
}

model VerticalLLMConfig {
  id               String            @id @default(cuid())
  verticalId       String
  providerConfigId String
  modelConfigId    String
  purpose          String?
  systemPrompt     String?
  configJson       Json?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vertical         Vertical          @relation(fields: [verticalId], references: [id], onDelete: Cascade)
  providerConfig   LLMProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  modelConfig      LLMModelConfig    @relation(fields: [modelConfigId], references: [id], onDelete: Restrict)

  @@index([verticalId])
  @@index([providerConfigId])
  @@index([modelConfigId])
  @@index([verticalId, active])
}

model EmailProviderConfig {
  id          String       @id @default(cuid())
  providerKey String       @unique
  name        String
  status      RecordStatus @default(ACTIVE)
  host        String?
  port        Int?
  usernameRef String?
  passwordRef String?
  fromEmail   String?
  fromName    String?
  configJson  Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
}

model EmailTemplate {
  id              String       @id @default(cuid())
  key             String       @unique
  name            String
  subjectTemplate String
  bodyTemplate    String
  type            String?
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([type])
}

model Person {
  id                 String                  @id @default(cuid())
  tenantId           String
  companyId          String?
  managerId          String?
  title              String?
  name               String
  email              String?
  role               String?
  department         String?
  active             Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company?                @relation(fields: [companyId], references: [id], onDelete: SetNull)
  manager            Person?                 @relation("OrgChartManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports            Person[]                @relation("OrgChartManager")
  ownedCustomers     Customer[]              @relation("CustomerOwner")
  ownedOpportunities Opportunity[]           @relation("OpportunityOwner")
  changedStageEvents OpportunityStageEvent[] @relation("ChangedBy")
  managedOrgUnits    OrgUnit[]               @relation("OrgUnitManager")
  teamMemberships    Team[]                  @relation("TeamManager")
  ownedAccounts      Account[]               @relation("AccountOwner")
  leadOwnership      Lead[]                  @relation("LeadOwner")
  quotePlans         PlanVersion[]           @relation("PlanVersionCreatedBy")
  decisionsOwned     Decision[]              @relation("DecisionOwner")
  risksOwned         Risk[]                  @relation("RiskOwner")
  notesAuthored      Note[]                  @relation("NoteAuthor")
  tasksOwned         Task[]                  @relation("TaskOwner")

  @@index([tenantId])
  @@index([companyId])
  @@index([tenantId, active])
  @@index([tenantId, email])
  @@index([tenantId, managerId])
}

model RevenueSnapshot {
  id              String      @id @default(cuid())
  tenantId        String
  companyId       String?
  timePeriodId    String?
  month           DateTime
  actualRevenue   Decimal     @db.Decimal(18, 2)
  forecastRevenue Decimal     @db.Decimal(18, 2)
  targetRevenue   Decimal     @db.Decimal(18, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  timePeriod      TimePeriod? @relation(fields: [timePeriodId], references: [id], onDelete: SetNull)

  @@unique([tenantId, month])
  @@index([tenantId])
  @@index([companyId])
  @@index([timePeriodId])
  @@index([tenantId, month])
}

model HeadcountSnapshot {
  id                String      @id @default(cuid())
  tenantId          String
  companyId         String?
  timePeriodId      String?
  month             DateTime
  actualHeadcount   Int
  forecastHeadcount Int
  targetHeadcount   Int
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company           Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  timePeriod        TimePeriod? @relation(fields: [timePeriodId], references: [id], onDelete: SetNull)

  @@unique([tenantId, month])
  @@index([tenantId])
  @@index([companyId])
  @@index([timePeriodId])
  @@index([tenantId, month])
}

model Customer {
  id            String         @id @default(cuid())
  tenantId      String
  name          String
  segment       String?
  geography     String?
  industry      String?
  status        CustomerStatus @default(PROSPECT)
  ownerId       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner         Person?        @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  orders        Order[]
  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerId])
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  customerId  String
  orderNumber String?
  orderDate   DateTime
  amount      Decimal     @db.Decimal(18, 2)
  status      OrderStatus @default(DRAFT)
  productLine String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([tenantId, orderDate])
  @@index([tenantId, status])
}

model SalesStage {
  id                 String                  @id @default(cuid())
  tenantId           String
  name               String
  stageOrder         Int
  defaultProbability Int?
  isClosedWon        Boolean                 @default(false)
  isClosedLost       Boolean                 @default(false)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunities      Opportunity[]
  stageEventsFrom    OpportunityStageEvent[] @relation("StageEventFrom")
  stageEventsTo      OpportunityStageEvent[] @relation("StageEventTo")

  @@unique([tenantId, name])
  @@unique([tenantId, stageOrder])
  @@index([tenantId])
